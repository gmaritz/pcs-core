// ==========================================================
// CATALOG
// ==========================================================

// ==========================================================
// SPORT
// ==========================================================

model Sport {

  // ========================================================
  // Primary Key
  // ========================================================

  id String @id @default(uuid())

  // ========================================================
  // Business Identity
  // ========================================================

  name String

  code String @unique

  slug String @unique

  // ========================================================
  // Business Information
  // ========================================================

  description String?

  displayOrder Int @default(0)

  // ========================================================
  // Status
  // ========================================================

  status RecordStatus @default(ACTIVE)

  // ========================================================
  // Auditing
  // ========================================================

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // ========================================================
  // Relationships
  // ========================================================

  categories Category[]

  brands Brand[]

  // ========================================================
  // Indexes
  // ========================================================

  @@index([displayOrder])

  // ========================================================
  // Database Mapping
  // ========================================================

  @@map("sports")
}


// ==========================================================
// CATEGORY
// ==========================================================

model Category {

  // ========================================================
  // Primary Key
  // ========================================================

  id String @id @default(uuid())

  // ========================================================
  // Business Identity
  // ========================================================

  name String

  code String @unique

  slug String @unique

  // ========================================================
  // Business Information
  // ========================================================

  description String?

  displayOrder Int @default(0)

  // ========================================================
  // Status
  // ========================================================

  status RecordStatus @default(ACTIVE)

  // ========================================================
  // Auditing
  // ========================================================

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // ========================================================
  // Relationships
  // ========================================================

  sportId String

  sport Sport @relation(fields: [sportId], references: [id])

  products Product[]

  // ========================================================
  // Indexes
  // ========================================================

  @@index([sportId])

  @@index([displayOrder])

  // ========================================================
  // Database Mapping
