generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================================
// GLOBAL CONVENTIONS
// ==========================================================

// Primary Keys
//
// id String @id @default(uuid())

// Auditing
//
// createdAt DateTime @default(now())
//
// updatedAt DateTime @updatedAt

// Status
//
// status RecordStatus @default(ACTIVE)

// ==========================================================
// ENUMS
// ==========================================================

// Enums will be added here as the domain model grows.

// Example:
//
// enum InventoryStatus {
//   IN_STOCK
//   LOW_STOCK
//   OUT_OF_STOCK
// }

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum ImportJobStatus {
  PENDING
  RUNNING
  COMPLETED
  COMPLETED_WITH_WARNINGS
  FAILED
  CANCELLED
  RETRYING
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  BACKORDERED
  RESERVED
  DISCONTINUED
}

// ==========================================================
// COMMERCE
// ==========================================================

// ==========================================================
// STORE
// ==========================================================

model Store {
  // ========================================================
  // Primary Key
  // ========================================================

  id String @id @default(uuid())

  // ========================================================
  // Business Identity
  // ========================================================

  name      String
  legalName String?
  code      String  @unique

  // ========================================================
  // Business Information
  // ========================================================

  email   String?
  phone   String?
  website String?

  // ========================================================
  // Status
  // ========================================================

  status RecordStatus @default(ACTIVE)

  // ========================================================
  // Auditing
  // ========================================================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ========================================================
  // Relationships
  // ========================================================

  currencies      Currency[]
  taxRates        TaxRate[]
  shippingMethods ShippingMethod[]
  paymentMethods  PaymentMethod[]

  // ========================================================
  // Database Mapping
  // ========================================================

  @@map("stores")
}

// ==========================================================
// CURRENCY
// ==========================================================

model Currency {
  // ========================================================
  // Primary Key
  // ========================================================

  id String @id @default(uuid())

  // ========================================================
  // Business Identity
  // ========================================================

  code String @unique
  name String

  // ========================================================
  // Business Information
  // ========================================================

  description String?

  symbol        String
  decimalPlaces Int    @default(2)

  // ========================================================
  // Status
  // ========================================================

  status RecordStatus @default(ACTIVE)

  // ========================================================
  // Auditing
  // ========================================================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ========================================================
  // Relationships
  // ========================================================

  storeId String

  store Store @relation(fields: [storeId], references: [id])

  // ========================================================
  // Indexes
  // ========================================================

  // ========================================================
  // Database Mapping
  // ========================================================

  @@index([storeId])
  @@map("currencies")
}

// ==========================================================
// TAX RATE
// ==========================================================

model TaxRate {
  // ========================================================
  // Primary Key
  // ========================================================

  id String @id @default(uuid())

  // ========================================================
  // Business Identity
  // ========================================================

  name String
  code String @unique

  // ========================================================
  // Business Information
  // ========================================================

  rate Decimal @db.Decimal(5, 2)

  isDefault Boolean @default(false)

  // ========================================================
  // Status
  // ========================================================

  status RecordStatus @default(ACTIVE)

  // ========================================================
  // Auditing
  // ========================================================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ========================================================
  // Relationships
  // ========================================================

  storeId String

  store Store @relation(fields: [storeId], references: [id])

  // ========================================================
  // Indexes
  // ========================================================

  // ========================================================
  // Database Mapping
  // ========================================================

  @@index([storeId])
  @@map("tax_rates")
}

