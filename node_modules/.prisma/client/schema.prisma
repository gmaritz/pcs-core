generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================================
// GLOBAL CONVENTIONS
// ==========================================================

// Primary Keys
//
// id String @id @default(uuid())

// Auditing
//
// createdAt DateTime @default(now())
//
// updatedAt DateTime @updatedAt

// Status
//
// status RecordStatus @default(ACTIVE)

// ==========================================================
// ENUMS
// ==========================================================

// Enums will be added here as the domain model grows.

// Example:
//
// enum InventoryStatus {
//   IN_STOCK
//   LOW_STOCK
//   OUT_OF_STOCK
// }

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum ImportJobStatus {
  PENDING
  RUNNING
  COMPLETED
  COMPLETED_WITH_WARNINGS
  FAILED
  CANCELLED
  RETRYING
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  BACKORDERED
  RESERVED
  DISCONTINUED
}

enum InventoryMovementType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
}

enum AddressType {
  SHIPPING
  BILLING
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum SpecificationDataType {
  TEXT
  INTEGER
  DECIMAL
  BOOLEAN
  DATE
}

// ==========================================================
// ARTICLE TYPE
// ==========================================================

enum ArticleType {
  BUYING_GUIDE
  REVIEW
  COMPARISON
  NEWS
  COACHING
  BRAND_STORY
  TOURNAMENT
  GENERAL
}

// ==========================================================
// ARTICLE STATUS
// ==========================================================

enum ArticleStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

