// ==========================================================
// STORE
// ==========================================================

model Store {
  // ========================================================
  // Primary Key
  // ========================================================

  id String @id @default(uuid())

  // ========================================================
  // Business Identity
  // ========================================================

  name      String
  legalName String?
  code      String  @unique

  // ========================================================
  // Business Information
  // ========================================================

  email   String?
  phone   String?
  website String?

  // ========================================================
  // Status
  // ========================================================

  status RecordStatus @default(ACTIVE)

  // ========================================================
  // Auditing
  // ========================================================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ========================================================
  // Relationships
  // ========================================================

  currencies      Currency[]
  taxRates        TaxRate[]
  shippingMethods ShippingMethod[]
  paymentMethods  PaymentMethod[]

  // ========================================================
  // Database Mapping
  // ========================================================

  @@map("stores")
}

// ==========================================================
// CURRENCY
// ==========================================================

model Currency {
  // ========================================================
  // Primary Key
  // ========================================================

  id String @id @default(uuid())

  // ========================================================
  // Business Identity
  // ========================================================

  code String @unique
