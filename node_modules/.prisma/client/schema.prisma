  // ========================================================
  // Auditing
  // ========================================================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ========================================================
  // Relationships
  // ========================================================

  storeId String

  store Store @relation(fields: [storeId], references: [id])

  // ========================================================
  // Indexes
  // ========================================================

  // ========================================================
  // Database Mapping
  // ========================================================

  @@index([storeId])
  @@map("currencies")
}

