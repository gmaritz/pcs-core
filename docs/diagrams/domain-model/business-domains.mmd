flowchart TB

%% ==========================================================
%% Business Domains
%% ==========================================================

COMMERCE["DOM-001
Commerce"]

CATALOG["DOM-002
Catalog"]

SUPPLY["DOM-003
Supply Chain"]

CUSTOMERS["DOM-004
Customers"]

SALES["DOM-005
Sales"]

CONTENT["DOM-006
Content"]

%% ==========================================================
%% Domain Responsibilities
%% ==========================================================

COMMERCE --> COMMERCE1["Platform Configuration"]
COMMERCE --> COMMERCE2["Currencies"]
COMMERCE --> COMMERCE3["Tax Rules"]
COMMERCE --> COMMERCE4["Shipping Methods"]
COMMERCE --> COMMERCE5["Payment Methods"]

CATALOG --> CATALOG1["Sports"]
CATALOG --> CATALOG2["Categories"]
CATALOG --> CATALOG3["Brands"]
CATALOG --> CATALOG4["Products"]
CATALOG --> CATALOG5["Product Variants"]
CATALOG --> CATALOG6["Attributes"]
CATALOG --> CATALOG7["Media"]

SUPPLY --> SUPPLY1["Suppliers"]
SUPPLY --> SUPPLY2["Supplier Products"]
SUPPLY --> SUPPLY3["Supplier Feeds"]
SUPPLY --> SUPPLY4["Inventory"]
SUPPLY --> SUPPLY5["Warehouses"]
SUPPLY --> SUPPLY6["Price History"]

CUSTOMERS --> CUSTOMER1["Customer Accounts"]
CUSTOMERS --> CUSTOMER2["Addresses"]
CUSTOMERS --> CUSTOMER3["Shopping Cart"]
CUSTOMERS --> CUSTOMER4["Wishlists"]

SALES --> SALES1["Orders"]
SALES --> SALES2["Payments"]
SALES --> SALES3["Shipments"]
SALES --> SALES4["Refunds"]

CONTENT --> CONTENT1["Pages"]
CONTENT --> CONTENT2["Articles"]
CONTENT --> CONTENT3["Hero Sections"]
CONTENT --> CONTENT4["Banners"]
CONTENT --> CONTENT5["Navigation"]
CONTENT --> CONTENT6["SEO Content"]

%% ==========================================================
%% Business Dependencies
%% ==========================================================

COMMERCE -. Supports .-> CATALOG
COMMERCE -. Supports .-> SUPPLY
COMMERCE -. Supports .-> CUSTOMERS
COMMERCE -. Supports .-> SALES
COMMERCE -. Supports .-> CONTENT

CATALOG --> SUPPLY

SUPPLY --> SALES

CUSTOMERS --> SALES

CONTENT -. Promotes .-> CATALOG

CONTENT -. Engages .-> CUSTOMERS

%% ==========================================================
%% Legend
%%
%% -->   Ownership / Business Dependency
%% -.->  Business Support / Association
%% ==>   Workflow / Process
%% ==========================================================

%% ==========================================================
%% Styles
%% ==========================================================

classDef core fill:#DCEEFF,stroke:#003366,stroke-width:3px

classDef capability fill:#F8F8F8,stroke:#888888,stroke-width:1px

class COMMERCE,CATALOG,SUPPLY,CUSTOMERS,SALES,CONTENT core

class COMMERCE1,COMMERCE2,COMMERCE3,COMMERCE4,COMMERCE5 capability

class CATALOG1,CATALOG2,CATALOG3,CATALOG4,CATALOG5,CATALOG6,CATALOG7 capability

class SUPPLY1,SUPPLY2,SUPPLY3,SUPPLY4,SUPPLY5,SUPPLY6 capability

class CUSTOMER1,CUSTOMER2,CUSTOMER3,CUSTOMER4 capability

class SALES1,SALES2,SALES3,SALES4 capability

class CONTENT1,CONTENT2,CONTENT3,CONTENT4,CONTENT5,CONTENT6 capability