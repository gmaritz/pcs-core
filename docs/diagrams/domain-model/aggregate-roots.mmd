flowchart LR

%% ==========================================================
%% Commerce Aggregate
%% ==========================================================

STORE["AGR-001 Store"]

STORE --> SETTINGS["Store Settings"]

STORE --> CURRENCY["Currency"]

STORE --> TAX["Tax Rate"]

STORE --> SHIPPING["Shipping Method"]

STORE --> PAYMENTMETHOD["Payment Method"]

%% ==========================================================
%% Catalog Aggregate
%% ==========================================================

PRODUCT["AGR-002 Product"]

PRODUCT --> VARIANT["Product Variant"]

PRODUCT --> ATTRIBUTE["Attribute"]

ATTRIBUTE --> ATTRIBUTEVALUE["Attribute Value"]

PRODUCT --> MEDIA["Media"]

%% ==========================================================
%% Supply Chain Aggregate
%% ==========================================================

SUPPLIER["AGR-003 Supplier"]

SUPPLIER --> SUPPLIERFEED["Supplier Feed"]

SUPPLIER --> IMPORTJOB["Import Job"]

SUPPLIER --> SUPPLIERPRODUCT["Supplier Product"]

SUPPLIER --> WAREHOUSE["Warehouse"]

SUPPLIER --> INVENTORY["Inventory"]

SUPPLIER --> PRICEHISTORY["Price History"]

SUPPLIER --> INVENTORYMOVEMENT["Inventory Movement"]

%% ==========================================================
%% Customer Aggregate
%% ==========================================================

CUSTOMER["AGR-004 Customer"]

CUSTOMER --> ADDRESS["Address"]

CUSTOMER --> SHOPPINGCART["Shopping Cart"]

SHOPPINGCART --> CARTITEM["Cart Item"]

CUSTOMER --> WISHLIST["Wishlist"]

%% ==========================================================
%% Sales Aggregate
%% ==========================================================

ORDER["AGR-005 Order"]

ORDER --> ORDERITEM["Order Item"]

ORDER --> PAYMENT["Payment"]

ORDER --> SHIPMENT["Shipment"]

ORDER --> REFUND["Refund"]

%% ==========================================================
%% Content Aggregate
%% ==========================================================

PAGE["AGR-006 Page"]

PAGE --> HERO["Hero"]

PAGE --> BANNER["Banner"]

PAGE --> NAVIGATION["Navigation"]

PAGE --> SEO["SEO Metadata"]

%% ==========================================================
%% Legend
%%
%% -->   Ownership
%% -.->  Reference / Association
%% ==>   Workflow / Process
%% ==========================================================

%% ==========================================================
%% Styles
%% ==========================================================

classDef aggregate fill:#DCEEFF,stroke:#003366,stroke-width:3px

classDef entity fill:#F8F8F8,stroke:#888888,stroke-width:1px

class STORE aggregate
class PRODUCT aggregate
class SUPPLIER aggregate
class CUSTOMER aggregate
class ORDER aggregate
class PAGE aggregate

class SETTINGS,CURRENCY,TAX,SHIPPING,PAYMENTMETHOD entity
class VARIANT,ATTRIBUTE,ATTRIBUTEVALUE,MEDIA entity
class SUPPLIERFEED,IMPORTJOB,SUPPLIERPRODUCT,WAREHOUSE,INVENTORY,PRICEHISTORY,INVENTORYMOVEMENT entity
class ADDRESS,SHOPPINGCART,CARTITEM,WISHLIST entity
class ORDERITEM,PAYMENT,SHIPMENT,REFUND entity
class HERO,BANNER,NAVIGATION,SEO entity