flowchart TB

%% ==========================================================
%% Catalog Domain
%% ==========================================================

SPORT["ENT-100 Sport"]

CATEGORY["ENT-101 Category"]

BRAND["ENT-102 Brand"]

PRODUCT["ENT-103 Product"]

VARIANT["ENT-104 Product Variant"]

ATTRIBUTE["ENT-105 Attribute"]

ATTRIBUTEVALUE["ENT-106 Attribute Value"]

MEDIA["ENT-107 Media"]

%% ==========================================================
%% Ownership Relationships
%% ==========================================================

PRODUCT --> VARIANT

PRODUCT --> ATTRIBUTE

ATTRIBUTE --> ATTRIBUTEVALUE

PRODUCT --> MEDIA

%% ==========================================================
%% Reference Relationships
%% ==========================================================

SPORT -. Classifies .-> PRODUCT

CATEGORY -. Categorises .-> PRODUCT

BRAND -. Brands .-> PRODUCT

ATTRIBUTEVALUE -. Describes .-> VARIANT

MEDIA -. Illustrates .-> VARIANT

%% ==========================================================
%% Future Cross-Domain References
%%
%% These entities belong to other bounded contexts.
%% They are included only to show future integration
%% points and are not owned by the Catalog Domain.
%% ==========================================================

SUPPLIERPRODUCT["ENT-203 Supplier Product"]

INVENTORY["ENT-205 Inventory"]

CARTITEM["ENT-304 Cart Item"]

ORDERITEM["ENT-401 Order Item"]

SUPPLIERPRODUCT -. References .-> VARIANT

INVENTORY -. References .-> VARIANT

CARTITEM -. References .-> VARIANT

ORDERITEM -. References .-> VARIANT

%% ==========================================================
%% Legend
%%
%% -->   Ownership
%% -.->  Reference / Association
%% ==>   Dependency / Process Flow
%% ==========================================================

