%% ==========================================================
%% Catalog Entities
%% ==========================================================

SPORT["ENT-100 Sport"]

CATEGORY["ENT-101 Category"]

BRAND["ENT-102 Brand"]

PRODUCT["ENT-103 Product"]

VARIANT["ENT-104 Product Variant"]

