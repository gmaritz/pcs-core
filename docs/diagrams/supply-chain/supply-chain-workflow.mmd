flowchart TD

%% ==========================================================
%% Workflow
%% ==========================================================

START([Scheduled or Manual Synchronisation])

FEED["ENT-201
Supplier Feed"]

IMPORT["ENT-202
Create Import Job"]

DOWNLOAD["Retrieve Supplier Data"]

VALIDATE{"Data Valid?"}

ERROR["Record Validation Errors"]

MATCH["Match Supplier Product
to Product Variant"]

UPSERT["Create / Update
Supplier Product"]

WAREHOUSE["Resolve Warehouse"]

INVENTORY["Update Inventory
(Current State)"]

MOVEMENT["Create Inventory
Movement"]

PRICE{"Price Changed?"}

PRICEHISTORY["Create Price
History Record"]

COMPLETE["Complete Import Job"]

END([Workflow Complete])

%% ==========================================================
%% Workflow
%% ==========================================================

START ==> FEED

FEED ==> IMPORT

IMPORT ==> DOWNLOAD

DOWNLOAD ==> VALIDATE

VALIDATE -- No --> ERROR

ERROR ==> COMPLETE

VALIDATE -- Yes --> MATCH

MATCH ==> UPSERT

UPSERT ==> WAREHOUSE

WAREHOUSE ==> INVENTORY

INVENTORY ==> MOVEMENT

MOVEMENT ==> PRICE

PRICE -- Yes --> PRICEHISTORY

PRICE -- No --> COMPLETE

PRICEHISTORY ==> COMPLETE

COMPLETE ==> END

%% ==========================================================
%% Legend
%%
%% ==>   Workflow / Process Flow
%% -->   Ownership (not used)
%% -.->  Reference / Association (not used)
