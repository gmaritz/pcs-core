%% Styles
%% ==========================================================

classDef start fill:#D5F5E3,stroke:#1E8449,stroke-width:2px

classDef process fill:#EBF5FB,stroke:#1F618D,stroke-width:1px

classDef decision fill:#FCF3CF,stroke:#B7950B,stroke-width:2px

classDef error fill:#FADBD8,stroke:#C0392B,stroke-width:2px

classDef finish fill:#D5F5E3,stroke:#1E8449,stroke-width:2px

class START start
class END finish

class FEED,IMPORT,DOWNLOAD,MATCH,UPSERT,WAREHOUSE,INVENTORY,MOVEMENT,PRICEHISTORY,COMPLETE process

class VALIDATE,PRICE decision

class ERROR error