flowchart LR

%% ==========================================================
%% Supply Chain Entities
%% ==========================================================

SUPPLIER["ENT-200 Supplier"]

SUPPLIERFEED["ENT-201 Supplier Feed"]

IMPORTJOB["ENT-202 Import Job"]

SUPPLIERPRODUCT["ENT-203 Supplier Product"]

WAREHOUSE["ENT-204 Warehouse"]

INVENTORY["ENT-205 Inventory"]

INVENTORYMOVEMENT["ENT-206 Inventory Movement"]

PRICEHISTORY["ENT-207 Price History"]

%% ==========================================================
%% External Reference
%% ==========================================================

PRODUCTVARIANT["ENT-104 Product Variant"]

%% ==========================================================
%% Ownership Relationships
%% ==========================================================

SUPPLIER --> SUPPLIERFEED

SUPPLIER --> IMPORTJOB

SUPPLIER --> SUPPLIERPRODUCT

SUPPLIER --> WAREHOUSE

WAREHOUSE --> INVENTORY

INVENTORY --> INVENTORYMOVEMENT

SUPPLIERPRODUCT --> PRICEHISTORY

%% ==========================================================
%% Reference Relationships
%% ==========================================================

SUPPLIERFEED -. Executes .-> IMPORTJOB

IMPORTJOB -. Creates / Updates .-> SUPPLIERPRODUCT

SUPPLIERPRODUCT -. Stocks .-> INVENTORY

SUPPLIERPRODUCT -. References .-> PRODUCTVARIANT

PRICEHISTORY -. Records Prices For .-> SUPPLIERPRODUCT

INVENTORYMOVEMENT -. Records Changes To .-> INVENTORY

%% ==========================================================
%% Cross-Domain Reference
%% ==========================================================

PRODUCTVARIANT -. Canonical Product .-> SUPPLIERPRODUCT

%% ==========================================================
