<section id="brands" class="section-shell">
  <% const brands = home?.brands?.items ?? []; %>

  <div class="page-shell">
    <div class="glass-card category-card">
      <p class="section-label font-display">Brands</p>
      <h2 class="section-title font-display">A Supplier-Ready Brand Mix</h2>

      <div class="brand-grid">
        <% if (brands.length > 0) { %>
          <% brands.slice(0, 5).forEach((brand) => { %>
            <div class="brand-pill <%= brand.themeClass %>"><%= brand.name %></div>
          <% }); %>
        <% } else { %>
          <div class="brand-pill brand-wilson">Wilson</div>
          <div class="brand-pill brand-head">Head</div>
          <div class="brand-pill brand-babolat">Babolat</div>
          <div class="brand-pill brand-tecnifibre">Tecnifibre</div>
          <div class="brand-pill brand-dunlop">Dunlop</div>
        <% } %>
      </div>

      <p class="card-copy">Brands subject to official supplier partnerships.</p>
    </div>
  </div>
</section>
