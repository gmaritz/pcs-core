<% if (pagination.totalPages > 1) { %>
  <nav class="ct-pagination" aria-label="Pagination">
    <% if (pagination.previousUrl) { %>
      <a href="<%= pagination.previousUrl %>" class="ct-pagination-link">Previous</a>
    <% } else { %>
      <span class="ct-pagination-link is-disabled">Previous</span>
    <% } %>

    <div class="ct-pagination-pages">
      <% pagination.pages.forEach((page) => { %>
        <a
          href="<%= page.url %>"
          class="ct-pagination-link <%= page.isCurrent ? 'is-current' : '' %>"
          <%= page.isCurrent ? 'aria-current=page' : '' %>
        ><%= page.label %></a>
      <% }); %>
    </div>

    <% if (pagination.nextUrl) { %>
      <a href="<%= pagination.nextUrl %>" class="ct-pagination-link">Next</a>
    <% } else { %>
      <span class="ct-pagination-link is-disabled">Next</span>
    <% } %>
  </nav>
<% } %>
